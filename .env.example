# ---- LLM ----
# Provider for the chat/agent model: "anthropic" (default) or "openai"
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
OPENAI_MODEL=gpt-4o

# OpenAI key is required for EMBEDDINGS even when LLM_PROVIDER=anthropic,
# because Anthropic does not provide an embeddings endpoint.
OPENAI_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536

# ---- Pinecone (knowledge base / unstructured) ----
PINECONE_API_KEY=
PINECONE_INDEX=sales-agent
PINECONE_CLOUD=aws
PINECONE_REGION=us-east-1

# ---- Supabase (CRM / structured) ----
SUPABASE_URL=
SUPABASE_KEY=

# ---- Retrieval ----
TOP_K=5
